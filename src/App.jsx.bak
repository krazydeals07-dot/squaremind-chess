import React from 'react';
import { BrowserRouter as Router, Routes, Route, Link } from 'react-router-dom';
import TournamentPage from './pages/TournamentPage';
import './App.css'; // आपण नंतर स्टायलिंगसाठी वापरू

function App() {
  return (
    <Router>
      <div className="App">
        <nav>
          <ul>
            <li>
              <Link to="/">Home</Link>
            </li>
            {/* भविष्यात येथे अधिक लिंक्स टाकता येतील */}
          </ul>
        </nav>

        <main>
          <Routes>
            <Route path="/" element={<TournamentPage />} />
          </Routes>
        </main>
      </div>
    </Router>
  );
}

export default App;
